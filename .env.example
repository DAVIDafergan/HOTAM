# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Sumit payments
# Use SUMIT_BUSINESS_ID and SUMIT_API_KEY as the canonical names.
# The code also reads SUMMIT_BUSINESS_ID / SUMMIT_PRIVATE_KEY as fallbacks (legacy).
NEXT_PUBLIC_SUMIT_BUSINESS_ID=        # public key shown in browser (Sumit dashboard → Public Key)
NEXT_PUBLIC_SUMIT_PUBLIC_KEY=         # same as above
SUMIT_BUSINESS_ID=                    # private — Sumit Company/Business ID
SUMIT_API_KEY=                        # private — Sumit API/Private Key
SUMIT_WEBHOOK_SECRET=                 # random strong string — must match what you set in Sumit dashboard header
PAYME_SELLER_ID=

# Email
RESEND_API_KEY=

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
